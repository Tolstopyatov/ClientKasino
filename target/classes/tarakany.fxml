<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="10.0" style="-fx-background-color: #2b2b2b;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.Tarakan">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button text="Главное меню" onAction="#openMainMenu" style="-fx-background-color: #6ea270; -fx-text-fill: white;"/>
            <Label fx:id="balanceLabel" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Баланс: 0" />
            <Label fx:id="raceStatusLabel" style="-fx-text-fill: #ffcc00; -fx-font-size: 16px;" text="Ставки открыты" />
         </children>
      </HBox>

      <!-- Игровое поле: дорожки для 6 тараканов -->
      <Pane fx:id="raceTrack" prefHeight="400.0" prefWidth="850.0" style="-fx-background-color: #5a3e1b; -fx-border-color: #d4a373; -fx-border-width: 3;"/>
      
      <!-- Панель выбора таракана и ставки -->
      <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #3c3c3c; -fx-padding: 10;">
         <children>
            <Label text="Выберите таракана:" textFill="white"/>
            <Button fx:id="roach1Btn" text="1" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach1"/>
            <Button fx:id="roach2Btn" text="2" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach2"/>
            <Button fx:id="roach3Btn" text="3" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach3"/>
            <Button fx:id="roach4Btn" text="4" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach4"/>
            <Button fx:id="roach5Btn" text="5" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach5"/>
            <Button fx:id="roach6Btn" text="6" style="-fx-background-color: #ffaa00; -fx-font-weight: bold;" onAction="#selectRoach6"/>
            <Label text="Ставка:" textFill="white"/>
            <TextField fx:id="betAmountField" prefWidth="80" promptText="сумма"/>
            <Button fx:id="placeBetButton" text="Сделать ставку" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" onAction="#placeBet"/>
         </children>
      </HBox>

      <!-- Лог сообщений -->
      <ScrollPane fitToWidth="true" prefHeight="120" style="-fx-background-color: #1e1e1e;">
         <content>
            <VBox fx:id="messageBox" spacing="3" style="-fx-background-color: #1e1e1e;"/>
         </content>
      </ScrollPane>
   </children>
</VBox>