<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Pane?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="10.0" style="-fx-background-color: #F0F2F5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.CockroachRaceController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>

   <children>
      <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
         <children>
            <Button text="Главное меню" onAction="#openMainMenu" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 5;"/>
            <Label fx:id="balanceLabel" style="-fx-text-fill: #333333; -fx-font-size: 18px; -fx-font-weight: bold;" text="Баланс: 0" />
            <Label fx:id="raceStatusLabel" style="-fx-text-fill: #FF6B6B; -fx-font-size: 16px; -fx-font-weight: bold;" text="Ожидание" />
         </children>
      </HBox>

      <Pane fx:id="raceTrack" prefHeight="400.0" prefWidth="850.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #007BFF; -fx-border-width: 2; -fx-background-radius: 8;"/>
      
      <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-background-radius: 8;">
         <children>
            <Label text="Выберите таракана:" textFill="#333333" style="-fx-font-weight: bold;"/>
            <Button fx:id="roach1Btn" text="1" onAction="#selectRoach1"/>
            <Button fx:id="roach2Btn" text="2" onAction="#selectRoach2"/>
            <Button fx:id="roach3Btn" text="3" onAction="#selectRoach3"/>
            <Button fx:id="roach4Btn" text="4" onAction="#selectRoach4"/>
            <Button fx:id="roach5Btn" text="5" onAction="#selectRoach5"/>
            <Button fx:id="roach6Btn" text="6" onAction="#selectRoach6"/>
            <Label text="Сумма:" textFill="#333333" style="-fx-font-weight: bold;"/>
            <TextField fx:id="betAmountField" text="10" prefWidth="80" promptText="сумма"/>
            <Button fx:id="placeBetButton" text="Сделать ставку" onAction="#placeBet" disable="true" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 5;"/>
         </children>
      </HBox>

      <VBox fx:id="chatBox" spacing="5" alignment="BOTTOM_LEFT" style="-fx-background-color: #FFFFFF; -fx-padding: 10; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-width: 1;" VBox.vgrow="ALWAYS">
         <children>
            <Label text="Чат" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #333333;"/>
            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8F9FA; -fx-background-radius: 5;">
               <content>
                  <VBox fx:id="chatContentBox" spacing="3" style="-fx-background-color: #F8F9FA; -fx-padding: 5;"/>
               </content>
            </ScrollPane>
            <HBox spacing="5" style="-fx-padding: 5;">
               <children>
                  <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" promptText="Введите сообщение..." style="-fx-background-color: #FFFFFF; -fx-text-fill: #333333; -fx-prompt-text-fill: #9e9e9e; -fx-border-color: #E0E0E0; -fx-border-width: 1; -fx-background-radius: 5; -fx-padding: 8;"/>
                  <Button text="Отправить" onAction="#sendChatMessage" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 5;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</VBox>