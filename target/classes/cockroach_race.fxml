<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F0F2F5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.CockroachRaceController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 10 20;">
         <children>
            <Button onAction="#openMainMenu" style="-fx-background-color: #6C757D; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;" text="Главное меню" />
            <Label style="-fx-text-fill: #343A40; -fx-font-size: 18px; -fx-font-weight: bold;" text="Тараканьи бега" />
            <Button onAction="#startRace" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;" text="Начать Забег" />
         </children>
      </HBox>
   </top>
   <center>
      <Pane fx:id="raceTrackPane" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #E9ECEF; -fx-border-color: #CED4DA; -fx-border-width: 1;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </BorderPane.margin>
      </Pane>
   </center>
</BorderPane>
