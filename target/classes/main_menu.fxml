<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" style="-fx-background-color: #222;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.MainMenuController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label text="Наше казино предлагает:" textFill="WHITE">
         <font>
            <Font name="System Bold" size="24.0" />
         </font>
      </Label>
      <Button onAction="#openRoulette" prefWidth="200.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 16px;" text="Рулетка" />
      <Button disable="true" prefWidth="200.0" style="-fx-background-color: #555; -fx-text-fill: white; -fx-font-size: 16px;" text="21 (Coming Soon)" />
      <Button onAction="#openCockroachRace" prefWidth="200.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 16px;" text="Тараканьи бега" />
      <Button disable="true" prefWidth="200.0" style="-fx-background-color: #555; -fx-text-fill: white; -fx-font-size: 16px;" text="Однорукий бандито (Coming Soon)" />
      <Button onAction="#logout" prefWidth="200.0" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 16px;" text="Выйти" />
   </children>
</VBox>
