<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import roulette.ui.TableCanvas?>

<BorderPane prefHeight="750.0" prefWidth="1200.0" style="-fx-background-color: #F0F2F5;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.RouletteController">
   <top>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-padding: 10 20;">
         <children>
            <Button onAction="#openMainMenu" style="-fx-background-color: #6C757D; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 15; -fx-background-radius: 5;" text="Главное меню" />
            <Label fx:id="balanceLabel" style="-fx-text-fill: #343A40; -fx-font-size: 18px; -fx-font-weight: bold;" text="Баланс: 0" />
            <Label fx:id="lastNumberLabel" style="-fx-text-fill: #343A40; -fx-font-size: 18px; -fx-font-weight: bold;" text="Последнее: -" />
         </children>
      </HBox>
   </top>
   <center>
      <HBox alignment="TOP_LEFT" spacing="10.0" BorderPane.alignment="CENTER">
         <children>
            <VBox alignment="TOP_CENTER" spacing="10.0" HBox.hgrow="ALWAYS">
               <children>
                  <TableCanvas fx:id="tableCanvas" height="500.0" width="800.0" style="-fx-border-color: #CED4DA; -fx-border-width: 1; -fx-background-color: #FFFFFF;" />
                  <HBox fx:id="chipPanelBox" alignment="CENTER" spacing="10.0" style="-fx-background-color: #E9ECEF; -fx-padding: 10; -fx-background-radius: 5;" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
            <VBox prefWidth="300.0" spacing="10.0" style="-fx-background-color: #FFFFFF; -fx-padding: 10; -fx-background-radius: 5;">
               <children>
                  <Label style="-fx-text-fill: #343A40; -fx-font-size: 16px; -fx-font-weight: bold;" text="Чат" />
                  <ScrollPane fx:id="messageScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #F8F9FA; -fx-border-color: #DEE2E6; -fx-border-width: 1;">
                     <content>
                        <VBox fx:id="messageContentBox" spacing="5.0" style="-fx-background-color: #F8F9FA;" />
                     </content>
                  </ScrollPane>
                  <HBox spacing="5.0">
                     <children>
                        <TextField fx:id="chatInputField" HBox.hgrow="ALWAYS" promptText="Введите сообщение..." style="-fx-background-color: #E9ECEF; -fx-border-color: #CED4DA; -fx-border-width: 1; -fx-background-radius: 5;" />
                        <Button onAction="#sendChatMessage" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 5 10; -fx-background-radius: 5;" text="Отправить" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </center>
</BorderPane>
