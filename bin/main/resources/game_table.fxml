<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import roulette.ui.TableCanvas?>

<VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="900.0" spacing="10.0" style="-fx-background-color: #222;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.RouletteController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Label fx:id="balanceLabel" style="-fx-text-fill: white; -fx-font-size: 18px;" text="Balance: 0" />
            <Label fx:id="lastNumberLabel" style="-fx-text-fill: white; -fx-font-size: 18px;" text="Last: -" />
         </children>
      </HBox>
      <TableCanvas fx:id="tableCanvas" height="400.0" width="880.0" />
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label style="-fx-text-fill: white;" text="Bet Amount:" />
            <TextField fx:id="betAmountField" prefWidth="100.0" promptText="Amount" />
            <Button fx:id="placeBetButton" text="Place Bet" />
         </children>
      </HBox>
      <ScrollPane fx:id="messageScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="messageContentBox" spacing="5.0" style="-fx-background-color: #333;" />
         </content>
      </ScrollPane>
   </children>
</VBox>
