<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import roulette.ui.TableCanvas?>

<VBox alignment="TOP_CENTER" prefHeight="700.0" prefWidth="1200.0" spacing="10.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="roulette.RouletteController">
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
   <children>
      <HBox alignment="CENTER" spacing="20.0">
         <children>
            <Button text="Главное меню" onAction="#openMainMenu" style="-fx-background-color: #6ea270; -fx-text-fill: white;"/>
            <Label fx:id="balanceLabel" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Баланс: 0" />
            <Label fx:id="lastNumberLabel" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Последнее: -" />
         </children>
      </HBox>
      <TableCanvas fx:id="tableCanvas" height="200.0" width="1000.0" style="-fx-border-color: #444; -fx-border-width: 2;" />
      <HBox fx:id="chipPanelBox" alignment="CENTER" spacing="10.0" style="-fx-background-color: #333; -fx-padding: 10;" />
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 14px;" text="Сумма ставки:" />
            <TextField fx:id="betAmountField" prefWidth="100.0" promptText="Введите число" />
            <Button fx:id="placeBetButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="Подтвердить ставку" />
         </children>
      </HBox>
      <ScrollPane fx:id="messageScrollPane" fitToWidth="true" prefHeight="150" style="-fx-background-color: #333;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="messageContentBox" spacing="5.0" style="-fx-background-color: #333;" />
         </content>
      </ScrollPane>
   </children>
</VBox>